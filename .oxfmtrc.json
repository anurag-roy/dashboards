{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "endOfLine": "lf",
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "jsxSingleQuote": true,
  "printWidth": 120,
  "sortTailwindcss": {
    "stylesheet": "packages/ui/src/styles/globals.css",
    "functions": ["cn", "cva"]
  },
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist/",
    "node_modules/",
    ".next/",
    ".turbo/",
    "coverage/",
    "**/next-env.d.ts",
    "pnpm-lock.yaml",
    ".pnpm-store/"
  ]
}
